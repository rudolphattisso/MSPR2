generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum LotStatus {
  CONFORME
  EN_ALERTE
  PERIME
}

enum AlertType {
  SEUIL_TEMPERATURE
  SEUIL_HUMIDITE
  PEREMPTION
}

enum UserRole {
  ADMIN
  MANAGER_PAYS
  VIEWER
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

// Country.id est un code pays explicite ("BR" | "EC" | "CO"), pas un UUID.
model Country {
  id                String      @id
  name              String
  idealTemp         Float
  tempTolerance     Float
  idealHumidity     Float
  humidityTolerance Float
  warehouses        Warehouse[]
  users             User[]

  @@map("countries")
}

// IDs UUID natifs PostgreSQL (gen_random_uuid()) — type UUID 16 octets,
// garanti globalement unique entre tous les backends pays sans coordination.
model Warehouse {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  countryId    String
  country      Country       @relation(fields: [countryId], references: [id])
  lots         Lot[]
  measurements Measurement[]

  @@map("warehouses")
}

model Lot {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference   String    @unique
  warehouseId String    @db.Uuid
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  storedAt    DateTime  @default(now())
  status      LotStatus @default(CONFORME)
  alerts      Alert[]

  @@map("lots")
}

// PK composite (id, recordedAt) requise par TimescaleDB :
// la colonne de partitionnement temporel doit faire partie de la PK
// pour garantir l'unicité au sein de chaque chunk interne.
model Measurement {
  id          String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  warehouseId String    @db.Uuid
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  temperature Float
  humidity    Float
  recordedAt  DateTime  @default(now())

  @@id([id, recordedAt])
  @@index([warehouseId, recordedAt])
  @@map("measurements")
}

model Alert {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lotId      String    @db.Uuid
  lot        Lot       @relation(fields: [lotId], references: [id], onDelete: Cascade)
  type       AlertType
  message    String
  isResolved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@map("alerts")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  password      String
  name          String
  role          UserRole  @default(VIEWER)
  countryId     String?
  country       Country?  @relation(fields: [countryId], references: [id])
  createdAt     DateTime  @default(now())
  // null = email non vérifié ; date = vérifié le ...
  emailVerified DateTime?

  @@map("users")
}

// Jetons de vérification d'email à usage unique (TTL ~24h).
model VerificationToken {
  token     String   @id
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("verification_tokens")
}
