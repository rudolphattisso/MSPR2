# Copier ce fichier en .env et adapter les valeurs

# PostgreSQL / TimescaleDB
POSTGRES_DB=futurekawa
POSTGRES_USER=futurekawa
POSTGRES_PASSWORD=futurekawa_secret
DATABASE_URL="postgresql://futurekawa:futurekawa_secret@localhost:5432/futurekawa"

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=futurekawa

# Pays déployé (BR | EC | CO)
COUNTRY_CODE=BR

# URLs backends pays (utilisées par app-siege)
BACKEND_BRESIL_URL=http://localhost:3001
BACKEND_EQUATEUR_URL=http://localhost:3001
BACKEND_COLOMBIE_URL=http://localhost:3001

# NextAuth (à compléter au Bloc 6)
NEXTAUTH_SECRET=changeme
NEXTAUTH_URL=http://localhost:3000
