# Copier ce fichier en .env et adapter les valeurs

# ============================================
# PostgreSQL / TimescaleDB
# ============================================

POSTGRES_DB=futurekawa
POSTGRES_USER=futurekawa
POSTGRES_PASSWORD=futurekawa_secret
DATABASE_URL="postgresql://futurekawa:futurekawa_secret@localhost:5432/futurekawa"

# ============================================
# MQTT
# ============================================

MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=futurekawa

# ============================================
# Pays déployé (BR | EC | CO)
# ============================================

COUNTRY_CODE=BR

# ============================================
# URLs des backends pays (utilisées par app-siege)
# Pour le prototype, les 3 pointent vers le même backend.
# ============================================

BACKEND_BRESIL_URL=http://localhost:3001
BACKEND_EQUATEUR_URL=http://localhost:3001
BACKEND_COLOMBIE_URL=http://localhost:3001

# ============================================
# Node-RED (Bloc 8)
# ============================================

# URL du backend pays appelé par Node-RED
BACKEND_PAYS_URL=http://host.docker.internal:3001

# Destinataire des emails d'alerte
ALERT_EMAIL_TO=responsable@futurekawa.com

# ============================================
# Authentification (Bloc 6)
# ============================================

# Secret utilisé par NextAuth pour signer les JWT
AUTH_SECRET=changeme

# URL de l'application siège
AUTH_URL=http://localhost:3000

# Backend pays qui gère les utilisateurs
AUTH_API_URL=http://localhost:3001

# Clé de service utilisée entre app-siege et backend-pays
# Elle doit être identique dans backend-pays/.env et app-siege/.env
SERVICE_API_KEY=changeme

# ============================================
# Vérification d'email
# ============================================

# Configuration par défaut : Mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=FutureKawa <no-reply@futurekawa.local>
APP_PUBLIC_URL=http://localhost:3000

# ============================================
# Configuration SMTP réelle (exemple Gmail)
# Décommenter uniquement pour les vrais envois.
# ============================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=ton@gmail.com
# SMTP_PASS=mot_de_passe_application