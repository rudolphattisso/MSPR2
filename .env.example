# Copier ce fichier en .env et adapter les valeurs

# PostgreSQL / TimescaleDB
POSTGRES_DB=futurekawa
POSTGRES_USER=futurekawa
POSTGRES_PASSWORD=futurekawa_secret
DATABASE_URL="postgresql://futurekawa:futurekawa_secret@localhost:5432/futurekawa"

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=futurekawa

# Pays déployé (BR | EC | CO)
COUNTRY_CODE=BR

# URLs backends pays (utilisées par app-siege)
BACKEND_BRESIL_URL=http://localhost:3001
BACKEND_EQUATEUR_URL=http://localhost:3001
BACKEND_COLOMBIE_URL=http://localhost:3001

# Node-RED — URL du backend pays appelé par Node-RED pour créer les alertes
# Sur Windows/Mac : http://host.docker.internal:3001 (valeur par défaut)
# Sur Linux       : http://host.docker.internal:3001 (résolu via extra_hosts dans docker-compose)
BACKEND_PAYS_URL=http://host.docker.internal:3001

# Node-RED — Configuration SMTP pour l'envoi des emails d'alerte
# Configurer également les credentials (login/mot de passe) via l'UI Node-RED : http://localhost:1880
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
ALERT_EMAIL_TO=responsable@futurekawa.com

# NextAuth (à compléter au Bloc 6)
NEXTAUTH_SECRET=changeme
NEXTAUTH_URL=http://localhost:3000
