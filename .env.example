# Copier ce fichier en .env et adapter les valeurs

# PostgreSQL / TimescaleDB
POSTGRES_DB=futurekawa
POSTGRES_USER=futurekawa
POSTGRES_PASSWORD=futurekawa_secret
DATABASE_URL="postgresql://futurekawa:futurekawa_secret@localhost:5432/futurekawa"

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=futurekawa

# Pays déployé (BR | EC | CO)
COUNTRY_CODE=BR

# URLs backends pays (utilisées par app-siege)
BACKEND_BRESIL_URL=http://localhost:3001
BACKEND_EQUATEUR_URL=http://localhost:3001
BACKEND_COLOMBIE_URL=http://localhost:3001

# === Auth (Bloc 6) ===

# NextAuth v5 — signe les JWT de session (app-siege). Générer une vraie valeur :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=changeme
AUTH_URL=http://localhost:3000

# Backend pays qui détient la table users (app-siege vérifie via /api/auth/login)
AUTH_API_URL=http://localhost:3001

# Clé de service M2M — exigée sur /api/* du backend pays (en-tête x-api-key).
# DOIT être IDENTIQUE dans backend-pays/.env et app-siege/.env. Générer :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_API_KEY=changeme

# === Email (vérification de compte — backend-pays) ===
# Par défaut : Mailhog (boîte locale http://localhost:8025, aucun envoi réel).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=FutureKawa <no-reply@futurekawa.local>
APP_PUBLIC_URL=http://localhost:3000
# Envois RÉELS via Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
#   SMTP_USER=ton@gmail.com, SMTP_PASS=mot_de_passe_application (myaccount.google.com/apppasswords)
